{
  "name": "palmetto-weather",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade weather application: NestJS API + React SPA with MongoDB caching, JWT auth, and OpenWeather integration.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm run start:dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,json,md}\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}